@article{sage2025_egyai_gt_bes_dispatch,
  title   = {Deep reinforcement learning for joint dispatch of battery storage and gas turbines in renewable-powered microgrids},
  author  = {Sage, Manuel and Al Handawi, Khalil and Zhao, Yaoyao Fiona},
  journal = {Energy and AI},
  volume  = {22},
  pages   = {100653},
  year    = {2025},
  doi     = {10.1016/j.egyai.2025.100653},
  abstract = {This study introduces a deep reinforcement learning framework for the joint dispatch of gas turbines and battery energy storage systems in renewable-powered microgrids. The work explicitly models gas-turbine ramp-up behavior and maintenance implications associated with operational cycling, and benchmarks several DRL methods against traditional dispatch approaches. The reported results show that learning-based control can produce more realistic dispatch patterns and reduce unnecessary gas-turbine starts, thereby improving the practical value of data-driven scheduling in hybrid energy systems.}
}

