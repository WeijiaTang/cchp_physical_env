@article{yang2026_ijepes_reward_dual_decoupling,
  title   = {Dual-decoupling of deep reinforcement learning reward function for integrated energy system scheduling: A collaborative mechanism of constraint separation and hierarchical decision-making},
  author  = {Yang, Xiangyan and Yang, Shaobing and Hu, Liang and Peng, Peng and Wu, Mingli},
  journal = {International Journal of Electrical Power \& Energy Systems},
  volume  = {174},
  pages   = {111467},
  year    = {2026},
  doi     = {10.1016/j.ijepes.2025.111467},
  abstract = {Deep reinforcement learning (DRL) applied to the integrated energy system (IES) scheduling tasks often leads to reward functions composed of multiple coupled components due to the complex structure of IES. However, reward design determines how agents perceive task objectives and action values, and excessive reward terms can cause policy confusion, resulting in suboptimal optimization. To address the multi-objective reward coupling challenge in IES optimal scheduling, this study proposes a DRL method based on a dual decoupling mechanism for reward functions. At the algorithmic level, this method reconstructs the Markov Decision Process (MDP) as a Constrained Markov Decision Process (CMDP) and introduces two improved algorithms, LTD3 and LSAC, combining dual decomposition to separate economic objectives from safety constraints in reward functions. At the architectural level, a hierarchical reinforcement learning framework (LTD3-LSAC) is established to decouple decision-making for electric units and thermal units, thereby separating electrical and thermal components in reward functions. Through a collaborative technical pathway combining horizontal algorithmic improvement and vertical architectural optimization, the proposed DRL method achieves dual decoupling of reward functions in IES scheduling tasks. Two-stage ablation experiment results show that the proposed LTD3-LSAC framework effectively improves the operational economy of IES: the total operational cost is reduced by 13.28% compared with the traditional strong penalty method, while the cumulative constraint violation index is controlled at 4.21, which is much lower than 36.78 of the weak penalty method; compared with the single-layer architecture, the hierarchical strategy further reduces the total operational cost by 3.23%. These results verify the superiority of the proposed dual decoupling mechanism in this study from the two dimensions of constraint handling and multi-energy coordination, respectively.}
}
@article{lyu2026_epsr_haasac_shared_storage,
  title   = {Deep reinforcement learning-based energy management strategy for heterogeneous interconnected multi-energy microgrid systems with shared energy storage},
  author  = {Lyu, Zengwei and Hu, Biao and Wei, Zhenchun and Zhou, Haodong and Bao, Hua and Guo, Zixin and Xu, Juan and Shi, Lei},
  journal = {Electric Power Systems Research},
  year    = {2026},
  doi     = {10.1016/j.epsr.2025.112375},
  abstract = {With the growing diversification of energy demand and large-scale integration of renewables, multi-energy microgrids show great potential in improving energy complementarity and grid stability. However, conventional optimization and standard multi-agent reinforcement learning (MARL) methods face difficulties in handling heterogeneous microgrid configurations, complex energy interactions, and uncertainties in load and renewable generation. To address these issues, this paper proposes a novel Heterogeneous-Agent Attention Soft Actor-Critic (HAASAC) algorithm, an advanced multi-agent deep reinforcement learning (MADRL) approach. The energy management problem is formulated as a Markov game, and a policy-wise sequential update mechanism is introduced to improve coordination among heterogeneous agents and alleviate non-stationarity. An attention mechanism is also embedded in the Critic network to dynamically model multi-energy couplings and agent interactions, a key enhancement over conventional MARL. Simulations demonstrate that HAASAC not only ensures stable training but also outperforms existing methods in reducing operational costs and enhanced coordination efficiency.}
}

